target/
# Fuzz corpus: only README.md files are tracked. Binary seeds and any
# libFuzzer mutation accumulators stay in local working copies; CI
# preserves crash-time corpora through the workflow's upload-artifact
# step instead of through the repository.
fuzz/corpus/*/*
!fuzz/corpus/*/README.md
fuzz/artifacts/
fuzz/target/
playwright-report/
test-results/
