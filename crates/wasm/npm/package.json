{
  "name": "cow-sdk-wasm-placeholder",
  "version": "0.1.0",
  "description": "TypeScript-callable wasm-bindgen bindings for the CoW Protocol Rust SDK",
  "license": "GPL-3.0-only",
  "homepage": "https://github.com/cowdao-grants/cow-rs",
  "repository": {
    "type": "git",
    "url": "https://github.com/cowdao-grants/cow-rs.git",
    "directory": "crates/wasm/npm"
  },
  "keywords": [
    "cow-protocol",
    "sdk",
    "wasm",
    "wasm-bindgen",
    "typescript",
    "eip-1193",
    "eip-1271"
  ],
  "type": "module",
  "main": "./dist/raw/default-nodejs/cow_sdk_wasm.cjs",
  "module": "./dist/raw/default-bundler/cow_sdk_wasm.js",
  "types": "./dist/raw/default-bundler/cow_sdk_wasm.d.ts",
  "exports": {
    ".": {
      "types": "./dist/raw/default-bundler/cow_sdk_wasm.d.ts",
      "node": {
        "types": "./dist/raw/default-nodejs/cow_sdk_wasm.d.ts",
        "require": "./dist/raw/default-nodejs/cow_sdk_wasm.cjs",
        "default": "./dist/raw/default-nodejs/cow_sdk_wasm.cjs"
      },
      "browser": {
        "types": "./dist/raw/default-web/cow_sdk_wasm.d.ts",
        "import": "./dist/raw/default-web/cow_sdk_wasm.js"
      },
      "import": "./dist/raw/default-bundler/cow_sdk_wasm.js",
      "default": "./dist/raw/default-bundler/cow_sdk_wasm.js"
    },
    "./orderbook": {
      "types": "./dist/raw/orderbook-bundler/cow_sdk_wasm.d.ts",
      "node": {
        "types": "./dist/raw/orderbook-nodejs/cow_sdk_wasm.d.ts",
        "require": "./dist/raw/orderbook-nodejs/cow_sdk_wasm.cjs",
        "default": "./dist/raw/orderbook-nodejs/cow_sdk_wasm.cjs"
      },
      "browser": {
        "types": "./dist/raw/orderbook-web/cow_sdk_wasm.d.ts",
        "import": "./dist/raw/orderbook-web/cow_sdk_wasm.js"
      },
      "import": "./dist/raw/orderbook-bundler/cow_sdk_wasm.js",
      "default": "./dist/raw/orderbook-bundler/cow_sdk_wasm.js"
    },
    "./signing": {
      "types": "./dist/raw/signing-bundler/cow_sdk_wasm.d.ts",
      "node": {
        "types": "./dist/raw/signing-nodejs/cow_sdk_wasm.d.ts",
        "require": "./dist/raw/signing-nodejs/cow_sdk_wasm.cjs",
        "default": "./dist/raw/signing-nodejs/cow_sdk_wasm.cjs"
      },
      "browser": {
        "types": "./dist/raw/signing-web/cow_sdk_wasm.d.ts",
        "import": "./dist/raw/signing-web/cow_sdk_wasm.js"
      },
      "import": "./dist/raw/signing-bundler/cow_sdk_wasm.js",
      "default": "./dist/raw/signing-bundler/cow_sdk_wasm.js"
    },
    "./full": {
      "types": "./dist/raw/full-bundler/cow_sdk_wasm.d.ts",
      "node": {
        "types": "./dist/raw/full-nodejs/cow_sdk_wasm.d.ts",
        "require": "./dist/raw/full-nodejs/cow_sdk_wasm.cjs",
        "default": "./dist/raw/full-nodejs/cow_sdk_wasm.cjs"
      },
      "browser": {
        "types": "./dist/raw/full-web/cow_sdk_wasm.d.ts",
        "import": "./dist/raw/full-web/cow_sdk_wasm.js"
      },
      "import": "./dist/raw/full-bundler/cow_sdk_wasm.js",
      "default": "./dist/raw/full-bundler/cow_sdk_wasm.js"
    },
    "./cloudflare": {
      "types": "./dist/raw/cloudflare-web/cow_sdk_wasm.d.ts",
      "browser": {
        "types": "./dist/raw/cloudflare-web/cow_sdk_wasm.d.ts",
        "import": "./dist/raw/cloudflare-web/cow_sdk_wasm.js"
      },
      "import": "./dist/raw/cloudflare-web/cow_sdk_wasm.js",
      "default": "./dist/raw/cloudflare-web/cow_sdk_wasm.js"
    },
    "./cloudflare/wasm": "./dist/raw/cloudflare-web/cow_sdk_wasm_bg.wasm"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
