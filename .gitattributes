# Normalize all text to LF in the repo and on checkout, overriding any local
# core.autocrlf=true. This keeps Windows checkouts from introducing CRLF, which
# would otherwise surface as spurious whole-file diffs. Binary files are
# auto-detected and left untouched.
* text=auto eol=lf

# Byte-exact fixtures and snapshots compared by tests via include_str!. These
# must stay LF on every host so comparisons against CI's LF output hold.
*.snap                                   text eol=lf
*.stderr                                 text eol=lf
crates/js/snapshots/**/*.d.ts          text eol=lf
parity/fixtures/**/*.json                text eol=lf

# Parser inputs read by parity tooling: vendored upstream snapshots, the DTO
# coverage manifest, and source-lock manifests with pinned commit hashes.
parity/openapi/**/*.yaml                 text eol=lf
parity/openapi/**/*.yml                  text eol=lf
parity/source-lock.yaml                  text eol=lf

# Raw EVM bytecode embedded via include_bytes!; never normalize or diff it.
crates/contracts/src/cow_shed/address/proxy-creation-code/*.bin   binary
