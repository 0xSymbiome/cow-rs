  "cases": [
    {
      "id": "contracts-order-type-fields",
      "kind": "contract-shape",
      "description": "Order field layout must match the canonical contracts TypeScript order type field order.",
      "expected": {
        "fields": [
          "sellToken",
          "buyToken",
          "receiver",
          "sellAmount",
          "buyAmount",
          "validTo",
          "appData",
          "feeAmount",
          "kind",
          "partiallyFillable",
          "sellTokenBalance",
          "buyTokenBalance"
        ]
      }
    },
    {
      "id": "contracts-order-type-hash",
      "kind": "positive",
      "description": "The canonical order type hash matches the public contracts-ts helper constant.",
      "expected": {
        "hash": "0xd5a25ba2e97094ad7d83dc28a6572da797d6b3e7fc6663bd93efb789fc17e489"
      }
    },
    {
      "id": "contracts-cancellation-type-fields",
      "kind": "contract-shape",
      "description": "Order cancellation typed data uses a single orderUids bytes[] field.",
      "expected": {
        "fields": [
          "orderUids"
        ]
      }
    },
    {
      "id": "contracts-order-uid-length",
      "kind": "positive",
      "description": "Packed order UIDs are 56 bytes and therefore 112 hex characters without the 0x prefix.",
      "expected": {
        "bytes": 56,
        "hex_chars": 112
      }
    },
    {
      "id": "contracts-extract-order-uid-invalid-length",
      "kind": "negative",
      "description": "Order UID extraction must reject payloads whose byte length is not 56.",
      "expected": {
        "must_reject": true,
        "error_contains": "invalid order UID length"
      }
    },
    {
      "id": "contracts-buy-balance-domain",
      "kind": "contract-shape",
      "description": "BuyTokenDestination is a closed type whose supported variants are the services enum {erc20, internal}; the external variant is sell-only and cannot be constructed on the buy-side destination type.",
      "expected": {
        "buy_token_destination_variants": [
          "erc20",
          "internal"
        ],
        "sell_token_source_variants": [
          "erc20",
          "external",
          "internal"
        ]
      }
    },
    {
      "id": "contracts-signing-scheme-discriminants",
      "kind": "contract-shape",
      "description": "Signing scheme discriminants must match the canonical on-chain encoding order.",
      "expected": {
        "EIP712": 0,
        "ETHSIGN": 1,
        "EIP1271": 2,
        "PRESIGN": 3
      }
    },
    {
      "id": "contracts-eip1271-magic-value",
      "kind": "positive",
      "description": "The EIP-1271 success value remains the standard 0x1626ba7e.",
      "expected": {
        "magic_value": "0x1626ba7e"
      }
    },
    {
      "id": "contracts-interaction-defaults",
      "kind": "behavior-scenario",
      "description": "Interaction normalization defaults missing value and calldata to zero-value call semantics.",
      "expected": {
        "value": "0",
        "call_data": "0x"
      }
    },
